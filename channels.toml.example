# channels.toml.example
# Copy this file to channels.toml and fill in your paths and channels.
# channels.toml is gitignored so your personal config stays local.

# Max parallel blog generation processes (default: 1 = sequential)
# max_parallel = 5

[paths]
# Local clone of your Hugo blog repo
blog_repo = "~/my-github-pages-blog"
# Subdirectory within blog_repo where posts go
blog_content_dir = "content/post"
# Branch to verify and push to
blog_branch = "master"
# Path to this youtube repo (for claude -d flag)
youtube_repo_dir = "~/youtube"
# Optional: path to LLM wiki project. Omit to skip wiki integration.
# llmwiki_dir = "~/llmwiki"

[hugo]
# Categories and tags for Hugo front matter
categories = ["youtube"]
tags = ["ai", "youtube"]

# Add your YouTube channels below. Find channel IDs by visiting
# the channel page and looking for the UC... string in the URL
# or page source.
#
# [[channel]]
# name = "Example AI Channel"
# channel_id = "UCxxxxxxxxxxxxxxxxxxxxxx"
